# Reference environment for the Jat services. Copy to .env and fill in. Never commit .env.

# Solana RPC the relayer and indexer use. A dedicated RPC is strongly recommended:
# public RPC rate-limits getProgramAccounts / getTransaction, which the indexer relies on.
RPC_URL=https://api.devnet.solana.com

# Relayer wallet: path to a FUNDED keypair JSON kept OUTSIDE the repo. This is a secret.
RELAYER_WALLET=/secure/path/relayer-wallet.json

# Relayer guardrails (lamports unless noted).
MAX_RELAYER_COST_LAMPORTS=10000000
RELAYER_MIN_BALANCE_LAMPORTS=50000000
RELAYER_RATE_PER_MIN=20
RELAYER_GLOBAL_PER_MIN=120

# Ports.
RELAYER_PORT=8789
INDEXER_PORT=8788

# What a browser/Node client points at (consumed by host apps, not the services).
NEXT_PUBLIC_RELAYER_URL=https://relayer.yourdomain
NEXT_PUBLIC_INDEXER_URL=https://indexer.yourdomain
